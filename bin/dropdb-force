#!/usr/bin/env bash
set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: dropdb-force <dbname>"
  echo "Terminates all connections to a database and drops it."
  exit 1
fi

dbname="$1"

echo "Terminating connections to '$dbname'..."
psql -d postgres -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '$dbname' AND pid <> pg_backend_pid();" > /dev/null

echo "Dropping database '$dbname'..."
dropdb "$dbname"

echo "Done."
