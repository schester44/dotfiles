[alias]
	recent = branch --sort=-committerdate --format=\"%(committerdate:relative)%09%(refname:short)\"
	ml = merge @{-1}
	diffv = -c delta.features=side-by-side diff

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only --syntax-theme dracula

[delta]
	navigate = true
	dark = true
	line-numbers = true

[merge]
	conflictStyle = zdiff3
[user]
	email = schester44@gmail.com
	name = Steve Chester
